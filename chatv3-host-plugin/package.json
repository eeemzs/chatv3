{
  "name": "@aopslab/domain-host-plugin-chatv3",
  "version": "0.1.1",
  "description": "ChatV3 host plugin: DomainPlugin registration, REST execute bridge, SSE runtime. Hostable in aops-server or any structural-compatible host.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit --incremental false",
    "test": "vitest run"
  },
  "dependencies": {
    "@aopslab/domain-dm-chatv3": "0.1.1",
    "@aopslab/domain-kit-chatv3": "0.1.1",
    "@aopslab/domain-pg-bootstrap-chatv3": "0.1.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/chatv3.git",
    "directory": "chatv3-host-plugin"
  }
}
